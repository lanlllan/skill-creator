def main():
    parser = argparse.ArgumentParser(
        description='{{ description | replace("'", "\\'") }}',
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument('--verbose', '-v', action='store_true', help='详细输出')
    subparsers = parser.add_subparsers(dest='command', help='可用命令')

{% for cmd in commands %}
{% if cmd.name %}
    parser_{{ cmd.name_snake }} = subparsers.add_parser(
        '{{ cmd.name }}', help='{{ cmd.description | replace("'", "\\'") }}'
    )
{% for arg in cmd.args %}
{% if arg.name %}
{% if arg.argparse_action %}
    parser_{{ cmd.name_snake }}.add_argument('{{ arg.arg_flag }}', action='{{ arg.argparse_action }}', help='{{ arg.description | replace("'", "\\'") }}')
{% else %}
    parser_{{ cmd.name_snake }}.add_argument('{{ arg.arg_flag }}', type={{ arg.type_python }}{% if arg.required %}, required=True{% endif %}, help='{{ arg.description | replace("'", "\\'") }}')
{% endif %}
{% endif %}
{% endfor %}

{% endif %}
{% endfor %}
    args = parser.parse_args()

    if args.verbose:
        print(f"🔍 调试模式：{args}")

    dispatch = {
{% for cmd in commands %}
{% if cmd.name %}
        '{{ cmd.name }}': cmd_{{ cmd.name_snake }},
{% endif %}
{% endfor %}
    }

    handler = dispatch.get(args.command)
    if not handler:
        parser.print_help()
        return 0

    try:
        result = handler(args)
    except Exception as e:
        print(f"❌ 未预期异常：{e}")
        return 1

    print(result.summary())
    if args.verbose and result.data:
        for k, v in result.data.items():
            print(f"  {k}: {v}")

    return 0 if result.success else 1


if __name__ == '__main__':
    sys.exit(main())
