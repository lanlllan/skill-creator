#!/usr/bin/env bash
# {{ description }}
set -euo pipefail

# 分级日志
log_ok()    { echo "✅ $*"; }
log_warn()  { echo "⚠️  $*" >&2; }
log_error() { echo "❌ $*" >&2; }

VERBOSE=false

{% for cmd in commands %}
{% if cmd.name %}
cmd_{{ cmd.name_snake }}() {
    # TODO 实现步骤：
    #   1. 解析命令行参数
    #   2. 执行核心逻辑
    #   3. 输出结果
    local result=""
{% for arg in cmd.args %}
{% if arg.name %}
{% if arg.argparse_action %}
    local {{ arg.name | replace('--', '') | replace('-', '_') }}=false
{% else %}
    local {{ arg.name | replace('--', '') | replace('-', '_') }}=""
{% endif %}
{% endif %}
{% endfor %}
    while [[ $# -gt 0 ]]; do
        case "$1" in
{% for arg in cmd.args %}
{% if arg.name %}
{% if arg.argparse_action %}
            {{ arg.arg_flag }}) {{ arg.name | replace('--', '') | replace('-', '_') }}=true; shift 1 ;;
{% else %}
            {{ arg.arg_flag }}) {{ arg.name | replace('--', '') | replace('-', '_') }}="$2"; shift 2 ;;
{% endif %}
{% endif %}
{% endfor %}
            *) log_error "未知参数: $1"; return 1 ;;
        esac
    done
    log_ok "{{ cmd.name }} 执行完成"
}

{% endif %}
{% endfor %}

show_help() {
    cat <<'HELP'
{{ description }}

用法: bash run.sh [全局选项] <命令> [命令选项]

全局选项:
  --verbose, -v    详细输出
  --help, -h       显示帮助

可用命令:
{% for cmd in commands %}
{% if cmd.name %}
  {{ cmd.name }}{{ ' ' * (16 - cmd.name | length) }}{{ cmd.description }}
{% endif %}
{% endfor %}
HELP
}

main() {
    if [[ $# -eq 0 ]]; then
        show_help
        exit 0
    fi

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --verbose|-v) VERBOSE=true; shift 1 ;;
            --help|-h)    show_help; exit 0 ;;
            *)            break ;;
        esac
    done

    local command="${1:-}"
    shift || true

    if [[ "$VERBOSE" == "true" ]]; then
        echo "🔍 调试模式：command=$command args=$*"
    fi

    case "$command" in
{% for cmd in commands %}
{% if cmd.name %}
        {{ cmd.name }}) cmd_{{ cmd.name_snake }} "$@" ;;
{% endif %}
{% endfor %}
        *)
            log_error "未知命令: $command"
            show_help
            exit 1
            ;;
    esac
}

main "$@"
